{
  "name": "@fci/crawler",
  "version": "0.1.0",
  "description": "Web crawler pipeline for full-content-inventory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fci-crawl": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.js",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@fci/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0",
    "unidecode": "^1.1.0",
    "csv-stringify": "^6.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.4",
    "@types/unidecode": "^0.1.3",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.0"
  }
}
